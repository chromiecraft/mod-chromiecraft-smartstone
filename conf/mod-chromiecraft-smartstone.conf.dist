[worldserver]

########################################
# ModChromiecraftSmartstone configuration
########################################
#
#    ModChromiecraftSmartstone.Enable
#        Description: Enable my module.
#        Default:     0 - Disabled
#                     1 - Enabled
#

ModChromiecraftSmartstone.Enable = 1

#    ModChromiecraftSmartstone.ItemID
#        Description: Item entry from item_template used as SmartStone.
#        Default:     32547
#

ModChromiecraftSmartstone.ItemID = 32547

#
#    ModChromiecraftSmartstone.Features.BarberDuration
#        Description: Sets the duration for the Barbershop Chair feature (in seconds).
#        Default:     300 Seconds (5 minutes)
#

ModChromiecraftSmartstone.Features.BarberDuration = 300


#
#    ModChromiecraftSmartstone.CanUseInArena
#        Description: Sets whether the SmartStone can be used in arenas.
#        Default:     0 - Disabled
#                     1 - Enabled
#

ModChromiecraftSmartstone.CanUseInArena = 0

#
#    ModChromiecraftSmartstone.CanUseInBG
#        Description: Sets whether the SmartStone can be used in battlegrounds.
#        Default:     0 - Disabled
#                     1 - Enabled
#

ModChromiecraftSmartstone.CanUseInBG = 0

#
#    ModChromiecraftSmartstone.CanUseInCombat
#        Description: Sets whether the SmartStone can be used in combat.
#        Default:     0 - Disabled
#                     1 - Enabled
#

ModChromiecraftSmartstone.CanUseInCombat = 0

#
#    ModChromiecraftSmartstone.CanUseInPvP
#        Description: Sets whether the SmartStone can be used in PvP.
#        Default:     0 - Disabled
#                     1 - Enabled
#

ModChromiecraftSmartstone.CanUseInPvP = 0

#
#    ModChromiecraftSmartstone.IndividualCostumeCooldowns
#        Description: When enabled, each costume has its own cooldown instead of sharing a global cooldown.
#        Default:     0 - Disabled (all costumes share the same cooldown)
#                     1 - Enabled (each costume has its own independent cooldown)
#

ModChromiecraftSmartstone.IndividualCostumeCooldowns = 0

# 
#    ModChromiecraftSmartstone.Debug
#        Description: Enables all Smartstone features by default.
#        Default:     0 - Disabled
#                     1 - Enabled
#

ModChromiecraftSmartstone.Debug = 0

#
#    ModChromiecraftSmartstone.CostumeConvert.Enable
#        Description: Enables the .smartstone costume convert command, which lets players convert
#                     legacy costume items (from the ac_world.costume table) into new Smartstone
#                     costume account unlocks. Requires the 'costume' table to exist in the world database.
#        Default:     0 - Disabled
#                     1 - Enabled
#

ModChromiecraftSmartstone.CostumeConvert.Enable = 0

#
#    ModChromiecraftSmartstone.UnlockMail.Enable
#        Description: When enabled, .smartstone unlock service / unlock account also sends the
#                     target player(s) a GM-stationery in-game mail informing them of the unlock.
#                     The in-game chat notification is always sent to connected players regardless
#                     of this setting; this option only controls the mail.
#        Default:     0 - Disabled (chat notification only)
#                     1 - Enabled (chat notification + GM mail)
#

ModChromiecraftSmartstone.UnlockMail.Enable = 0

#
#    ModChromiecraftSmartstone.ChallengeXpReset.Enable
#        Description: When enabled, challenge characters (marker auras 2000100/2000101/2000102)
#                     have their mod-weekend-xp rate snapped back to 1x on login and level-up,
#                     and are notified in chat if their rate was non-default.
#        Default:     1 - Enabled
#                     0 - Disabled
#

ModChromiecraftSmartstone.ChallengeXpReset.Enable = 1

#
#    ModChromiecraftSmartstone.DisplayOptOut.Enable
#        Description: Enables the per-player "hide other players' display overrides" toggles
#                     (costumes / druid-shaman form skins / warlock-pet & feral-spirit skins),
#                     exposed via the Character > Display Options menu and
#                     .smartstone toggle costumes|forms|minions. When disabled, the menu entry
#                     and commands are unavailable and every player sees all overrides normally.
#        Default:     1 - Enabled
#                     0 - Disabled
#

ModChromiecraftSmartstone.DisplayOptOut.Enable = 1
